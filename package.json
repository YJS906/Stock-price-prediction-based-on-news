{
  "name": "newsalpha-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/shared"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint",
    "typecheck:web": "npm --workspace apps/web run typecheck",
    "test:web": "npm --workspace apps/web run test",
    "test:api": "cd apps/api && pytest",
    "test:ml": "cd ml && pytest",
    "compose:up": "docker compose -f infra/docker-compose.yml up --build",
    "compose:down": "docker compose -f infra/docker-compose.yml down -v"
  }
}
